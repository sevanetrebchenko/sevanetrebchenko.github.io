---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SeriesWidget from '../components/SeriesWidget.astro';
import Footer from '../components/Footer.astro';

const { frontmatter, headings, seriesPosts, currentPostId } = Astro.props;

const hasSeries = seriesPosts && seriesPosts.length >= 2;

const publishDate = frontmatter.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Only show "Updated" if lastModified is more than 7 days after publish
const modifiedDate = (() => {
  if (!frontmatter.lastModified) return null;
  const diff = frontmatter.lastModified.valueOf() - frontmatter.date.valueOf();
  if (diff < 7 * 24 * 60 * 60 * 1000) return null;
  return frontmatter.lastModified.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
})();
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.abstract}
  ogType="article"
>
  <!-- JSON-LD structured data for blog post -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: frontmatter.title,
      description: frontmatter.abstract,
      datePublished: frontmatter.date.toISOString(),
      dateModified: (frontmatter.lastModified || frontmatter.date).toISOString(),
      author: {
        "@type": "Person",
        name: "Seva Netrebchenko",
      },
    })}
  />

  <div class="min-h-screen max-w-5xl mx-auto px-6 relative">
    <!-- Back nav (desktop) -->
    <div class="hidden lg:block absolute top-0 bottom-0 right-full">
      <div class="sticky pt-10 pr-8" style="top: var(--header-height);">
        <a
          href="/blog"
          class="flex items-center justify-center w-10 h-10 rounded text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-accent)] dark:hover:text-[var(--color-dark-accent)] hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)] transition-colors no-underline"
          aria-label="Back to blog"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Article -->
    <article
      class="min-w-0 w-full py-10"
      data-pagefind-body
    >
      <!-- Post header: tags → title → date -->
      <header class="mb-8 pb-6 border-b border-[var(--color-light-border)] dark:border-[var(--color-dark-border)]">
        <!-- Tags -->
        {frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {frontmatter.tags.map((tag) => (
              <a
                href={`/blog?tag=${encodeURIComponent(tag)}`}
                class="font-mono text-sm px-2.5 py-1 rounded bg-[var(--color-light-border)] dark:bg-[var(--color-dark-border)] text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors no-underline"
              >
                {tag}
              </a>
            ))}
          </div>
        )}

        <!-- Title -->
        <h1 class="font-serif text-3xl sm:text-4xl font-semibold leading-tight text-[var(--color-light-text)] dark:text-[var(--color-dark-text)]" style="letter-spacing: -0.01em;">
          {frontmatter.title}
        </h1>

        <!-- Date -->
        <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-serif text-sm text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
          <time datetime={frontmatter.date.toISOString()}>{publishDate}</time>
          {modifiedDate && <span>·</span>}
          {modifiedDate && <span>Updated {modifiedDate}</span>}
        </div>
      </header>

      <!-- Post body -->
      <div class="prose prose-base dark:prose-invert max-w-none
        text-[var(--color-light-text)] dark:text-[var(--color-dark-text)]
        prose-headings:font-serif prose-headings:tracking-[0.01em]
        prose-headings:text-[var(--color-light-text)] dark:prose-headings:text-[var(--color-dark-text)]
        prose-p:text-[var(--color-light-text)] dark:prose-p:text-[var(--color-dark-text)]
        prose-strong:text-[var(--color-light-text)] dark:prose-strong:text-[var(--color-dark-text)]
        prose-li:text-[var(--color-light-text)] dark:prose-li:text-[var(--color-dark-text)]
        prose-a:text-[var(--color-light-accent)] dark:prose-a:text-[var(--color-dark-accent)]
        prose-code:font-mono prose-code:text-[0.95em]
        prose-hr:border-[var(--color-light-border)] dark:prose-hr:border-[var(--color-dark-border)]">
        <slot />
      </div>

      <!-- Series navigation -->
      {hasSeries && (
        <SeriesWidget seriesPosts={seriesPosts} currentPostId={currentPostId} variant="top" />
      )}

      <!-- Post footer -->
      <footer class="mt-12 pt-6">
        <Footer />
      </footer>
    </article>

    <!-- TOC (desktop xl+) -->
    <div class="hidden xl:block absolute top-0 bottom-0 left-full">
      <div class="sticky pt-10 pl-8 w-64" style="top: var(--header-height);">
        <TableOfContents headings={headings} />
      </div>
    </div>
  </div>
</BaseLayout>

<script src="../utils/code-blocks.js"></script>
