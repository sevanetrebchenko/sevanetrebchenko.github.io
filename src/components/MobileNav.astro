---
const { currentPath = '' } = Astro.props;

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];

function isActive(href) {
  if (href === '/blog') return currentPath.startsWith('/blog') || currentPath.startsWith('/tags');
  return currentPath.startsWith(href);
}
---

<!-- Mobile nav overlay -->
<div
  id="mobile-nav"
  class="fixed inset-0 z-[60] pointer-events-none"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div
    id="mobile-nav-backdrop"
    class="absolute inset-0 bg-black/60 opacity-0 transition-opacity duration-200"
  ></div>

  <!-- Drawer from right -->
  <div
    id="mobile-nav-drawer"
    class="absolute top-0 right-0 h-full w-72 max-w-[85vw] translate-x-full transition-transform duration-200 ease-out bg-[var(--color-light-surface)] dark:bg-[var(--color-dark-surface)] border-l border-[var(--color-light-border)] dark:border-[var(--color-dark-border)] flex flex-col"
  >
    <!-- Drawer header -->
    <div class="flex items-center justify-between px-5 border-b border-[var(--color-light-border)] dark:border-[var(--color-dark-border)]" style="height: var(--header-height)">
      <span class="font-serif text-xs uppercase tracking-widest text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] opacity-60">Menu</span>
      <button
        id="mobile-nav-close"
        class="p-2 text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors"
        aria-label="Close menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex flex-col px-4 py-6 gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'block px-3 py-2.5 rounded-md font-serif text-sm transition-colors no-underline',
            isActive(href)
              ? 'text-[var(--color-light-accent)] dark:text-[var(--color-dark-accent)] font-semibold bg-[var(--color-light-border)] dark:bg-[var(--color-dark-border)]'
              : 'text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)]',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Footer actions -->
    <div class="mt-auto px-5 py-5 border-t border-[var(--color-light-border)] dark:border-[var(--color-dark-border)] flex items-center gap-3">
      <button
        onclick="window.__searchOpen && (window.__searchClose && window.__searchClose(), setTimeout(window.__searchOpen, 50))"
        class="flex items-center gap-2 text-sm text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
        </svg>
        <span class="font-serif text-xs">Search</span>
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const nav = document.getElementById('mobile-nav');
    const backdrop = document.getElementById('mobile-nav-backdrop');
    const drawer = document.getElementById('mobile-nav-drawer');
    const closeBtn = document.getElementById('mobile-nav-close');
    let isOpen = false;

    function openNav() {
      isOpen = true;
      nav.setAttribute('aria-hidden', 'false');
      nav.classList.remove('pointer-events-none');
      backdrop.classList.remove('opacity-0');
      backdrop.classList.add('opacity-100');
      drawer.classList.remove('translate-x-full');
      document.body.style.overflow = 'hidden';
    }

    function closeNav() {
      isOpen = false;
      nav.setAttribute('aria-hidden', 'true');
      nav.classList.add('pointer-events-none');
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      drawer.classList.add('translate-x-full');
      document.body.style.overflow = '';
    }

    backdrop.addEventListener('click', closeNav);
    closeBtn.addEventListener('click', closeNav);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeNav();
    });

    window.__mobileNavOpen = openNav;
    window.__mobileNavClose = closeNav;
  })();
</script>
