---
const { post } = Astro.props;
const { title, abstract, tags, date } = post.data;
const href = `/blog/${post.id}`;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card relative group rounded-[10px] bg-[var(--color-light-surface)] dark:bg-[var(--color-dark-surface)] p-6 mb-6 border border-transparent transition-colors duration-150 hover:border-[rgb(50,50,50)]">

  <h2 class="font-serif text-2xl font-semibold leading-snug">
    <a
      href={href}
      class="no-underline text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] group-hover:text-[var(--color-light-accent)] dark:group-hover:text-[var(--color-dark-accent)] transition-colors duration-150 after:absolute after:inset-0 after:content-['']"
    >
      {title}
    </a>
  </h2>

  <time
    class="mt-2 block font-serif text-sm text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]"
    datetime={date.toISOString()}
  >
    {formattedDate}
  </time>

  <p class="mt-3 text-base text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] leading-relaxed line-clamp-2">
    {abstract}
  </p>

  <div class="relative z-10 flex flex-wrap items-center gap-1.5 mt-4">
    {tags.map((tag) => (
      <a
        href={`/tags/${tag}`}
        data-tag={tag}
        class="post-tag font-mono text-sm px-2.5 py-1 rounded bg-[var(--color-light-border)] dark:bg-[var(--color-dark-border)] text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors no-underline"
      >
        {tag}
      </a>
    ))}
  </div>
</article>
