---
const year = new Date().getFullYear();
---

<footer class="flex flex-col items-center gap-3 pt-6 border-t border-[var(--color-light-border)] dark:border-[var(--color-dark-border)]">
  <div class="flex gap-5 text-xl text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
    <a href="https://github.com/sevanetrebchenko/" aria-label="GitHub" class="hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors">
      <i class="fab fa-github fa-fw"></i>
    </a>
    <a href="https://www.linkedin.com/in/sevanetrebchenko/" aria-label="LinkedIn" class="hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors">
      <i class="fab fa-linkedin fa-fw"></i>
    </a>
    <a href="https://www.youtube.com/@sevanetrebchenko" aria-label="YouTube" class="hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors">
      <i class="fab fa-youtube fa-fw"></i>
    </a>
  </div>
  <span class="text-sm text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
    &copy; {year} Seva Netrebchenko
  </span>
</footer>
