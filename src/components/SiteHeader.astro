---
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
];

function isActive(href) {
  if (href === '/blog') return currentPath.startsWith('/blog') || currentPath.startsWith('/tags') || currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header" id="site-header">
  <div class="h-full max-w-5xl mx-auto px-6 grid grid-cols-[1fr_auto] md:grid-cols-[1fr_auto_1fr] items-center gap-4">

    <!-- Site name -->
    <a
      href="/blog"
      class="font-serif font-semibold text-lg text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] hover:text-[var(--color-light-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors no-underline shrink-0"
    >
      Seva Netrebchenko
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Site navigation">
      {navLinks.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            class:list={[
              'relative px-3 py-1.5 font-serif text-base transition-colors no-underline',
              active
                ? 'text-[var(--color-light-accent)] dark:text-[var(--color-dark-accent)]'
                : 'text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)]',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {label}
            {active && (
              <span class="absolute bottom-0 left-3 right-3 h-0.5 rounded-full bg-[var(--color-light-accent)] dark:bg-[var(--color-dark-accent)]"></span>
            )}
          </a>
        );
      })}
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2 justify-end">
      <!-- Theme toggle (desktop) -->
      <div class="hidden md:block">
        <ThemeToggle />
      </div>

      <!-- Hamburger (mobile) -->
      <button
        id="mobile-nav-trigger"
        aria-label="Open menu"
        class="md:hidden p-2 text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>

<MobileNav currentPath={currentPath} />

<script is:inline>
  // Mobile nav trigger
  document.getElementById('mobile-nav-trigger').addEventListener('click', () => {
    window.__mobileNavOpen && window.__mobileNavOpen();
  });
</script>
