---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getTagCounts } from '../../utils/blog.js';

const posts = await getPublishedPosts();
const tagCounts = getTagCounts(posts);
const allTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);
---

<BlogLayout title="Blog" description="Writing about graphics programming, C++, and software development.">

  <!-- Search + filter UI -->
  <div id="blog-search-wrapper" class="mb-10">

    <!-- Input row -->
    <div class="blog-search-row flex items-center gap-3 pb-3">
      <svg
        class="blog-search-icon w-5 h-5 shrink-0 text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] transition-colors duration-150"
        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
      </svg>
      <input
        id="blog-search-input"
        type="text"
        placeholder="Type something..."
        autocomplete="off"
        spellcheck="false"
        class="flex-1 bg-transparent outline-none font-serif text-base text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] placeholder:text-[var(--color-light-text-secondary)] dark:placeholder:text-[var(--color-dark-text-secondary)] placeholder:opacity-50"
      />
      <kbd
        id="search-kbd-hint"
        class="hidden sm:inline-flex items-center px-1.5 py-0.5 rounded border border-[var(--color-light-border)] dark:border-[var(--color-dark-border)] font-mono text-xs text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] opacity-50 shrink-0"
      >/</kbd>
      <button
        id="clear-search"
        class="hidden text-lg leading-none text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors shrink-0 px-2"
        aria-label="Clear search and filters"
        type="button"
      >
        ✕
      </button>
    </div>

    <!-- Tag panel: expands on focus -->
    <div id="tag-panel" class="tag-panel">
      <div id="pills-container" class="flex flex-wrap gap-y-2 pt-3 items-center" style="transition: padding 250ms ease, gap 250ms ease;">
        {allTags.map(([tag, count]) => (
          <button
            class="tag-filter-pill inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md font-mono text-sm bg-[var(--color-light-border)] dark:bg-[var(--color-dark-border)] text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] cursor-pointer"
            data-tag={tag}
            type="button"
          >
            {tag}
            <span class="opacity-40">{count}</span>
          </button>
        ))}
        <button
          id="more-tags-btn"
          type="button"
          style="display:none"
          class="more-tags-btn inline-flex items-center px-2.5 py-1 rounded-md font-mono text-sm cursor-pointer shrink-0"
        ></button>
      </div>
    </div>

  </div>

  <!-- Post list -->
  <div id="post-list">
    {posts.map((post) => (
      <div
        class="post-item"
        data-title={post.data.title.toLowerCase()}
        data-abstract={(post.data.abstract || '').toLowerCase()}
        data-tags={post.data.tags.join(',')}
      >
        <PostCard post={post} />
      </div>
    ))}
  </div>

  <p id="no-results" class="hidden text-center font-serif text-base italic text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] py-12">
    No posts found.
  </p>

  <!-- Pagination -->
  <nav id="pagination" class="hidden flex items-center justify-center gap-6 pt-8" aria-label="Pagination">
    <button
      id="page-prev"
      type="button"
      class="flex items-center justify-center w-9 h-9 rounded text-2xl text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)] transition-colors disabled:opacity-30 disabled:pointer-events-none"
      aria-label="Previous page"
    ><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg></button>
    <span id="page-numbers" class="flex gap-3"></span>
    <button
      id="page-next"
      type="button"
      class="flex items-center justify-center w-9 h-9 rounded text-2xl text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)] transition-colors disabled:opacity-30 disabled:pointer-events-none"
      aria-label="Next page"
    ><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></button>
  </nav>

</BlogLayout>

<script is:inline>
(function () {
  const wrapper        = document.getElementById('blog-search-wrapper');
  const input          = document.getElementById('blog-search-input');
  const tagPanel       = document.getElementById('tag-panel');
  const pillsContainer = document.getElementById('pills-container');
  const moreBtn        = document.getElementById('more-tags-btn');
  const clearBtn       = document.getElementById('clear-search');
  const kbdHint        = document.getElementById('search-kbd-hint');
  const noResults      = document.getElementById('no-results');
  const searchRow      = wrapper.querySelector('.blog-search-row');

  const PER_PAGE = 6;
  let currentPage   = 1;
  let activeTags    = new Set();
  let panelOpen     = false;
  let debounce;
  let moreBtnTimer  = null;

  const pagination   = document.getElementById('pagination');
  const pageNumbers  = document.getElementById('page-numbers');
  const prevBtn      = document.getElementById('page-prev');
  const nextBtn      = document.getElementById('page-next');

  // ── Pill helpers ─────────────────────────────────────────────────────

  function hidePill(p) {
    const cs = getComputedStyle(p);
    const w = p.offsetWidth;
    p.style.width         = w + 'px';
    p.style.minWidth      = '0';
    p.style.marginRight   = cs.marginRight;
    p.style.borderWidth   = cs.borderWidth;
    p.style.paddingLeft   = cs.paddingLeft;
    p.style.paddingRight  = cs.paddingRight;
    void p.offsetWidth;
    p.style.width         = '0';
    p.style.marginRight   = '0';
    p.style.borderWidth   = '0';
    p.style.paddingLeft   = '0';
    p.style.paddingRight  = '0';
    p.style.opacity       = '0';
    p.style.pointerEvents = 'none';
  }

  function showPill(p) {
    p.style.width         = '';
    p.style.minWidth      = '';
    p.style.marginRight   = '';
    p.style.borderWidth   = '';
    p.style.paddingLeft   = '';
    p.style.paddingRight  = '';
    p.style.opacity       = '';
    p.style.pointerEvents = '';
  }

  // ── Expand ───────────────────────────────────────────────────────────

  function expandPanel() {
    if (panelOpen) return;
    panelOpen = true;
    clearTimeout(moreBtnTimer);
    searchRow.classList.add('focused');
    kbdHint.style.opacity = '0';
    kbdHint.style.pointerEvents = 'none';
    moreBtn.style.display = 'none';

    // Reset pills instantly (no transition) before revealing the panel
    pillsContainer.querySelectorAll('.tag-filter-pill').forEach(p => {
      p.style.transition = 'none';
      showPill(p);
    });
    pillsContainer.style.paddingTop = '';
    pillsContainer.style.gap = '';
    void pillsContainer.offsetWidth; // force layout with transitions disabled

    // Re-enable transitions, then reveal
    pillsContainer.querySelectorAll('.tag-filter-pill').forEach(p => {
      p.style.transition = '';
    });
    tagPanel.style.gridTemplateRows = '1fr';
    tagPanel.style.opacity = '1';
  }

  // ── Collapse ─────────────────────────────────────────────────────────

  function collapsePanel() {
    if (!panelOpen) return;
    panelOpen = false;

    const hasFilters = !!(input.value.trim()) || activeTags.size > 0;
    searchRow.classList.toggle('focused', hasFilters);
    if (!hasFilters) { kbdHint.style.opacity = ''; kbdHint.style.pointerEvents = ''; }

    if (activeTags.size > 0) {
      const inactivePills = [...pillsContainer.querySelectorAll('.tag-filter-pill')]
        .filter(p => !activeTags.has(p.dataset.tag));

      // Animate inactive pills out and collapse row gap to prevent snap
      // when an entire row of pills disappears
      inactivePills.forEach(hidePill);
      pillsContainer.style.gap = '0';

      // Show the more button after pills finish collapsing, fading in
      const count = inactivePills.length;
      moreBtn.textContent = `+${count} more`;
      moreBtn.style.display = '';
      moreBtn.style.opacity = '0';
      moreBtnTimer = setTimeout(() => {
        moreBtn.style.opacity = '';
      }, 250);
    } else {
      tagPanel.style.gridTemplateRows = '0fr';
      tagPanel.style.opacity = '0';
    }
  }

  wrapper.addEventListener('focusin', function() {
    if (window.scrollY > 0) {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    expandPanel();
  });
  wrapper.addEventListener('focusout', () => {
    setTimeout(() => { if (!wrapper.contains(document.activeElement)) collapsePanel(); }, 0);
  });

  // ── Filter ──────────────────────────────────────────────────────────

  function filterPosts(resetPage) {
    if (resetPage !== false) currentPage = 1;

    const query = input.value.trim().toLowerCase();
    const items = [...document.querySelectorAll('.post-item')];
    const matched = [];

    items.forEach(item => {
      const title    = item.dataset.title    || '';
      const abstract = item.dataset.abstract || '';
      const itemTags = (item.dataset.tags || '').split(',').map(t => t.trim().toLowerCase());

      const textMatch = !query || title.includes(query) || abstract.includes(query) || itemTags.some(t => t.includes(query));
      const tagMatch  = activeTags.size === 0 || [...activeTags].every(t => itemTags.includes(t));

      if (textMatch && tagMatch) matched.push(item);
    });

    const totalPages = Math.max(1, Math.ceil(matched.length / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * PER_PAGE;
    const end = start + PER_PAGE;

    items.forEach(item => item.style.display = 'none');
    matched.forEach((item, i) => {
      item.style.display = (i >= start && i < end) ? '' : 'none';
    });

    noResults.classList.toggle('hidden', matched.length > 0);
    renderPagination(totalPages);
    syncPillStates();
    const hasFilters = !!input.value.trim() || activeTags.size > 0;
    clearBtn.classList.toggle('hidden', !hasFilters);
    if (!panelOpen) { kbdHint.style.opacity = hasFilters ? '0' : ''; kbdHint.style.pointerEvents = hasFilters ? 'none' : ''; }
  }

  function renderPagination(totalPages) {
    if (totalPages <= 1) { pagination.classList.add('hidden'); return; }
    pagination.classList.remove('hidden');

    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;

    // Build page numbers with ellipsis for large page counts
    // Always show: first, last, current, and 1 neighbor on each side
    var pages = [];
    for (var i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || Math.abs(i - currentPage) <= 1) {
        pages.push(i);
      }
    }

    pageNumbers.innerHTML = '';
    var prev = 0;
    pages.forEach(function(p) {
      if (prev && p - prev > 1) {
        var dots = document.createElement('span');
        dots.textContent = '\u2026';
        dots.className = 'px-2 py-1.5 font-serif text-base text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] opacity-50 select-none';
        pageNumbers.appendChild(dots);
      }
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = p;
      btn.className = 'px-3 py-1.5 rounded font-serif text-base transition-colors ';
      if (p === currentPage) {
        btn.className += 'text-[var(--color-light-accent)] dark:text-[var(--color-dark-accent)] font-semibold';
      } else {
        btn.className += 'text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)]';
      }
      btn.addEventListener('click', function() { goToPage(p); });
      pageNumbers.appendChild(btn);
      prev = p;
    });
  }

  function goToPage(page) {
    currentPage = page;
    filterPosts(false);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  prevBtn.addEventListener('click', () => goToPage(currentPage - 1));
  nextBtn.addEventListener('click', () => goToPage(currentPage + 1));

  // ── Pill states ─────────────────────────────────────────────────────

  function syncPillStates() {
    const applyActive = (el, active) => {
      el.classList.toggle('bg-[var(--color-light-accent)]',               active);
      el.classList.toggle('dark:bg-[var(--color-dark-accent)]',           active);
      el.classList.toggle('text-white',                                   active);
      el.classList.toggle('dark:text-[var(--color-dark-bg)]',             active);
      el.classList.toggle('bg-[var(--color-light-border)]',              !active);
      el.classList.toggle('dark:bg-[var(--color-dark-border)]',          !active);
      el.classList.toggle('text-[var(--color-light-text-secondary)]',    !active);
      el.classList.toggle('dark:text-[var(--color-dark-text-secondary)]',!active);
    };

    pillsContainer.querySelectorAll('.tag-filter-pill').forEach(pill => {
      applyActive(pill, activeTags.has(pill.dataset.tag));
    });

    document.querySelectorAll('.post-tag').forEach(tag => {
      applyActive(tag, activeTags.has(tag.dataset.tag));
    });
  }

  // ── Summary refresh (pill clicked while panel is closed) ────────────

  function refreshSummary() {
    const hasFilters = !!input.value.trim() || activeTags.size > 0;
    searchRow.classList.toggle('focused', hasFilters);

    if (activeTags.size > 0) {
      let inactiveCount = 0;
      pillsContainer.querySelectorAll('.tag-filter-pill').forEach(pill => {
        if (activeTags.has(pill.dataset.tag)) {
          showPill(pill);
        } else {
          hidePill(pill);
          inactiveCount++;
        }
      });
      moreBtn.textContent = `+${inactiveCount} more`;
      moreBtn.style.display = inactiveCount > 0 ? '' : 'none';
      tagPanel.style.gridTemplateRows = '1fr';
      tagPanel.style.opacity = '1';
    } else {
      moreBtn.style.display = 'none';
      input.focus();
    }
  }

  // ── Tag pill clicks ─────────────────────────────────────────────────

  pillsContainer.querySelectorAll('.tag-filter-pill').forEach(pill => {
    pill.addEventListener('mousedown', (e) => {
      if (!panelOpen) e.preventDefault();
    });
    pill.addEventListener('click', () => {
      const tag = pill.dataset.tag;
      activeTags.has(tag) ? activeTags.delete(tag) : activeTags.add(tag);
      filterPosts();
      syncTagsToURL();
      if (!panelOpen) refreshSummary();
    });
  });

  // ── More tags button ────────────────────────────────────────────────

  moreBtn.addEventListener('mousedown', (e) => e.preventDefault());
  moreBtn.addEventListener('click', () => input.focus());

  // ── Post card tag clicks ────────────────────────────────────────────

  document.querySelectorAll('.post-tag').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      activeTags.add(link.dataset.tag);
      filterPosts();
      syncTagsToURL();
      if (!panelOpen) refreshSummary();
    });
  });

  // ── Input ───────────────────────────────────────────────────────────

  input.addEventListener('input', () => { clearTimeout(debounce); debounce = setTimeout(filterPosts, 80); });

  // ── Clear ───────────────────────────────────────────────────────────

  clearBtn.addEventListener('mousedown', (e) => e.preventDefault());

  clearBtn.addEventListener('click', () => {
    input.value = '';
    activeTags.clear();
    filterPosts();
    syncTagsToURL();
    panelOpen = false;
    moreBtn.style.display = 'none';
    tagPanel.style.gridTemplateRows = '0fr';
    tagPanel.style.opacity = '0';
    searchRow.classList.remove('focused');
    kbdHint.style.opacity = '';
    kbdHint.style.pointerEvents = '';
    input.blur();
  });

  // ── / shortcut ──────────────────────────────────────────────────────

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT' && document.activeElement?.tagName !== 'TEXTAREA') {
      e.preventDefault();
      var rect = input.getBoundingClientRect();
      var isVisible = rect.top >= 0 && rect.bottom <= window.innerHeight;
      input.focus({ preventScroll: true });
      if (!isVisible) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      input.blur();
    }
  });

  // ── URL ↔ tag sync ─────────────────────────────────────────────────

  function syncTagsToURL() {
    const url = new URL(window.location);
    url.searchParams.delete('tag');
    activeTags.forEach(t => url.searchParams.append('tag', t));
    history.replaceState(null, '', url);
  }

  // Read tags from URL on load
  const urlTags = new URLSearchParams(window.location.search).getAll('tag');
  if (urlTags.length) {
    urlTags.forEach(t => activeTags.add(t));
    refreshSummary();
  }

  // Initial render with pagination
  filterPosts();
})();
</script>
