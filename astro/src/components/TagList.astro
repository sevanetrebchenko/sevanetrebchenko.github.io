---
const { tags, activeTag } = Astro.props;
// tags: Map<string, number>
// activeTag: string | undefined
---

<div class="flex flex-col gap-2">
  <div class="flex flex-wrap gap-x-3 gap-y-1.5">
    {Array.from(tags).sort(([a], [b]) => a.localeCompare(b)).map(([tag, count]) => {
      const isActive = activeTag === tag;
      const href = isActive ? '/blog' : `/tags/${tag}`;
      return (
        <a
          href={href}
          class:list={[
            'inline-flex items-center gap-1 text-sm transition-colors duration-150 no-underline rounded px-1.5 py-0.5',
            isActive
              ? 'bg-[var(--color-light-accent)] dark:bg-[var(--color-dark-accent)] text-white dark:text-[var(--color-dark-bg)] font-medium'
              : 'text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)]',
          ]}
        >
          <span>{tag}</span>
          <span class="opacity-50 text-xs">({count})</span>
          {isActive && (
            <svg class="w-3 h-3 ml-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          )}
        </a>
      );
    })}
  </div>
</div>
