---
import { getPublishedPosts, getTagCounts } from '../lib/blog.js';

const allPosts = await getPublishedPosts();
const tagCounts = getTagCounts(allPosts);
const tags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);

const postsData = allPosts.map(p => ({
  url: `/blog/${p.id}`,
  title: p.data.title,
  date: p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
  tags: p.data.tags,
}));
---

<div id="search-overlay" class="search-overlay" role="dialog" aria-modal="true" aria-label="Search">
  <div class="search-panel flex flex-col" id="search-panel" style="max-height: 75vh;">

    <!-- Input row -->
    <div class="flex items-center gap-3 px-4 py-3 border-b border-[var(--color-light-border)] dark:border-[var(--color-dark-border)] shrink-0">
      <svg class="w-4 h-4 shrink-0 text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search posts..."
        autocomplete="off"
        spellcheck="false"
        class="flex-1 bg-transparent outline-none font-mono text-sm text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] placeholder:text-[var(--color-light-text-secondary)] dark:placeholder:text-[var(--color-dark-text-secondary)] placeholder:opacity-50"
      />
      <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 rounded border border-[var(--color-light-border)] dark:border-[var(--color-dark-border)] font-mono text-xs text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
        Esc
      </kbd>
    </div>

    <!-- Topics -->
    <div class="px-4 pt-4 pb-3 border-b border-[var(--color-light-border)] dark:border-[var(--color-dark-border)] shrink-0">
      <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] opacity-70 mb-3">
        Topics
      </p>
      <div class="flex flex-wrap gap-2 max-h-28 overflow-y-auto" id="topic-pills">
        {tags.map(([tag, count]) => (
          <button
            class="topic-pill inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md font-mono text-xs bg-[var(--color-light-border)] dark:bg-[var(--color-dark-border)] text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-text)] dark:hover:text-[var(--color-dark-text)] transition-colors cursor-pointer"
            data-tag={tag}
            type="button"
          >
            {tag}
            <span class="opacity-40">{count}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Results -->
    <div class="flex-1 overflow-y-auto min-h-0">
      <div id="search-results-list" class="p-2"></div>
      <div id="search-empty" class="hidden py-10 text-center font-mono text-sm text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
        No results for "<span id="search-empty-query"></span>"
      </div>
    </div>

  </div>
</div>

<script id="search-posts-data" type="application/json" set:html={JSON.stringify(postsData)}></script>

<script is:inline>
  (function () {
    const ALL_POSTS = JSON.parse(document.getElementById('search-posts-data').textContent);

    const overlay    = document.getElementById('search-overlay');
    const input      = document.getElementById('search-input');
    const resultsList = document.getElementById('search-results-list');
    const emptyEl    = document.getElementById('search-empty');
    const emptyQuery = document.getElementById('search-empty-query');

    let pagefind = null;
    let isOpen = false;
    let activeTags = [];
    let debounce;

    // ── Tag management ──────────────────────────────────────────────────

    function syncPillStates() {
      document.querySelectorAll('.topic-pill').forEach(btn => {
        const active = activeTags.includes(btn.dataset.tag);
        btn.classList.toggle('bg-[var(--color-light-accent)]', active);
        btn.classList.toggle('dark:bg-[var(--color-dark-accent)]', active);
        btn.classList.toggle('text-white', active);
        btn.classList.toggle('dark:text-[var(--color-dark-bg)]', active);
        btn.classList.toggle('bg-[var(--color-light-border)]', !active);
        btn.classList.toggle('dark:bg-[var(--color-dark-border)]', !active);
        btn.classList.toggle('text-[var(--color-light-text-secondary)]', !active);
        btn.classList.toggle('dark:text-[var(--color-dark-text-secondary)]', !active);
      });
    }

    document.querySelectorAll('.topic-pill').forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;
        activeTags = activeTags.includes(tag)
          ? activeTags.filter(t => t !== tag)
          : [...activeTags, tag];
        syncPillStates();
        updateResults();
      });
    });

    // ── Result HTML ─────────────────────────────────────────────────────

    function sectionLabel(text) {
      return `<p class="font-mono text-xs uppercase tracking-widest text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] opacity-70 px-3 pt-3 pb-2">${text}</p>`;
    }

    function postHTML(post) {
      return `
        <a href="${post.url}" class="flex items-baseline justify-between gap-4 px-3 py-2.5 rounded-md hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)] transition-colors no-underline group">
          <span class="font-serif text-sm font-semibold text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] group-hover:text-[var(--color-light-accent)] dark:group-hover:text-[var(--color-dark-accent)] transition-colors leading-snug">${post.title}</span>
          <span class="font-mono text-xs text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] shrink-0 opacity-60">${post.date}</span>
        </a>`;
    }

    function searchResultHTML(r) {
      const date = r.meta?.date ?? '';
      const excerpt = r.excerpt
        ? `<p class="font-mono text-xs text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] mt-0.5 opacity-70 line-clamp-1">${r.excerpt}</p>`
        : '';
      return `
        <a href="${r.url}" class="block px-3 py-2.5 rounded-md hover:bg-[var(--color-light-border)] dark:hover:bg-[var(--color-dark-border)] transition-colors no-underline group">
          <div class="flex items-baseline justify-between gap-4">
            <span class="font-serif text-sm font-semibold text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] group-hover:text-[var(--color-light-accent)] dark:group-hover:text-[var(--color-dark-accent)] transition-colors leading-snug">${r.meta?.title ?? r.url}</span>
            ${date ? `<span class="font-mono text-xs text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] shrink-0 opacity-60">${date}</span>` : ''}
          </div>
          ${excerpt}
        </a>`;
    }

    // ── Results update ──────────────────────────────────────────────────

    async function updateResults() {
      const query = input.value.trim();

      // No text, no tags → recent posts
      if (!query && activeTags.length === 0) {
        emptyEl.classList.add('hidden');
        resultsList.innerHTML = sectionLabel('Recent') + ALL_POSTS.slice(0, 5).map(postHTML).join('');
        return;
      }

      // No text, tags selected → filter posts by tags
      if (!query) {
        const filtered = ALL_POSTS.filter(p => activeTags.every(t => p.tags.includes(t)));
        if (filtered.length === 0) {
          resultsList.innerHTML = '';
          emptyQuery.textContent = 'the selected topics';
          emptyEl.classList.remove('hidden');
        } else {
          emptyEl.classList.add('hidden');
          const label = filtered.length === 1 ? '1 post' : `${filtered.length} posts`;
          resultsList.innerHTML = sectionLabel(label) + filtered.map(postHTML).join('');
        }
        return;
      }

      // Text search (requires pagefind)
      if (!pagefind) {
        await loadPagefind();
        if (!pagefind) return;
      }

      try {
        const results = await pagefind.search(query);
        let data = await Promise.all(results.results.slice(0, 20).map(r => r.data()));

        // Cross-filter by active tags using the build-time posts index
        if (activeTags.length > 0) {
          const tagsByUrl = Object.fromEntries(ALL_POSTS.map(p => [p.url, p.tags]));
          data = data.filter(r => {
            const postTags = tagsByUrl[r.url] || [];
            return activeTags.every(t => postTags.includes(t));
          });
        }

        if (data.length === 0) {
          resultsList.innerHTML = '';
          emptyQuery.textContent = activeTags.length > 0 ? `"${query}" with selected topics` : `"${query}"`;
          emptyEl.classList.remove('hidden');
        } else {
          emptyEl.classList.add('hidden');
          resultsList.innerHTML = data.map(searchResultHTML).join('');
        }
      } catch (e) {}
    }

    // ── Pagefind ────────────────────────────────────────────────────────

    async function loadPagefind() {
      if (pagefind) return;
      try {
        const script = document.createElement('script');
        script.type = 'module';
        script.textContent = `
          import * as pf from '/pagefind/pagefind.js';
          await pf.options({ excerptLength: 20 });
          window.__pagefind = pf;
          document.dispatchEvent(new Event('pagefind-loaded'));
        `;
        document.head.appendChild(script);
        await new Promise(resolve =>
          document.addEventListener('pagefind-loaded', resolve, { once: true })
        );
        pagefind = window.__pagefind;
      } catch (e) { /* pagefind not built yet in dev */ }
    }

    // ── Open / close ────────────────────────────────────────────────────

    function open(opts = {}) {
      if (isOpen) return;
      isOpen = true;
      overlay.classList.add('open');
      input.value = '';

      if (opts.tag && !activeTags.includes(opts.tag)) {
        activeTags = [...activeTags, opts.tag];
      }

      input.focus();
      document.body.style.overflow = 'hidden';
      syncPillStates();
      updateResults();
      loadPagefind();
    }

    function close() {
      if (!isOpen) return;
      isOpen = false;
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) { e.preventDefault(); close(); return; }
      if (e.key === '/' && !isOpen &&
          document.activeElement?.tagName !== 'INPUT' &&
          document.activeElement?.tagName !== 'TEXTAREA') {
        e.preventDefault(); open();
      }
    });

    input.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(updateResults, 150);
    });

    window.__searchOpen = open;
    window.__searchClose = close;
  })();
</script>
