---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import SeriesWidget from '../components/SeriesWidget.astro';
import Footer from '../components/Footer.astro';

const { frontmatter, headings, seriesPosts, currentPostId } = Astro.props;

const hasSeries = seriesPosts && seriesPosts.length >= 2;

const publishDate = frontmatter.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

// Only show "Updated" if lastModified is more than 7 days after publish
const modifiedDate = (() => {
  if (!frontmatter.lastModified) return null;
  const diff = frontmatter.lastModified.valueOf() - frontmatter.date.valueOf();
  if (diff < 7 * 24 * 60 * 60 * 1000) return null;
  return frontmatter.lastModified.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
})();
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.abstract}
  ogType="article"
>
  <!-- JSON-LD structured data for blog post -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: frontmatter.title,
      description: frontmatter.abstract,
      datePublished: frontmatter.date.toISOString(),
      dateModified: (frontmatter.lastModified || frontmatter.date).toISOString(),
      author: {
        "@type": "Person",
        name: "Seva Netrebchenko",
      },
    })}
  />

  <div class="min-h-screen flex justify-center">
    <!-- Back nav (desktop) -->
    <div class="hidden lg:flex flex-col items-end w-20 shrink-0 pt-10 pr-4 sticky h-screen" style="top: var(--header-height);">
      <a
        href="/blog"
        class="text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors no-underline"
        aria-label="Back to blog"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
    </div>

    <!-- Article -->
    <article
      class="flex-1 min-w-0 px-4 sm:px-6 py-10"
      style="max-width: 68ch;"
      data-pagefind-body
    >
      <!-- Post header: tags → title → date -->
      <header class="mb-8 pb-6 border-b border-[var(--color-light-border)] dark:border-[var(--color-dark-border)]">
        <!-- Tags -->
        {frontmatter.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-3">
            {frontmatter.tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="font-mono text-xs px-2 py-0.5 rounded bg-[var(--color-light-border)] dark:bg-[var(--color-dark-border)] text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)] hover:text-[var(--color-light-accent)] dark:hover:text-[var(--color-dark-accent)] transition-colors no-underline"
              >
                {tag}
              </a>
            ))}
          </div>
        )}

        <!-- Title -->
        <h1 class="font-serif text-3xl sm:text-4xl font-semibold leading-tight text-[var(--color-light-text)] dark:text-[var(--color-dark-text)]" style="letter-spacing: -0.01em;">
          {frontmatter.title}
        </h1>

        <!-- Date -->
        <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-xs text-[var(--color-light-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
          <time datetime={frontmatter.date.toISOString()}>{publishDate}</time>
          {modifiedDate && <span>Updated {modifiedDate}</span>}
        </div>
      </header>

      <!-- Series top banner -->
      {hasSeries && (
        <SeriesWidget seriesPosts={seriesPosts} currentPostId={currentPostId} variant="top" />
      )}

      <!-- Post body -->
      <div class="prose prose-lg dark:prose-invert max-w-none
        prose-headings:font-serif
        prose-a:text-[var(--color-light-accent)] dark:prose-a:text-[var(--color-dark-accent)]
        prose-code:font-mono prose-code:text-[0.9em]
        prose-pre:bg-[var(--color-code-bg)] prose-pre:text-[var(--color-code-text)]">
        <slot />
      </div>

      <!-- Series bottom index -->
      {hasSeries && (
        <SeriesWidget seriesPosts={seriesPosts} currentPostId={currentPostId} variant="bottom" />
      )}

      <!-- Post footer -->
      <footer class="mt-12 pt-6 border-t border-[var(--color-light-border)] dark:border-[var(--color-dark-border)]">
        <Footer />
      </footer>
    </article>

    <script src="../scripts/code-blocks.js"></script>

    <!-- TOC (desktop xl+) -->
    <div class="hidden xl:block w-52 shrink-0 pt-10 pl-6">
      <TableOfContents headings={headings} />
    </div>
  </div>
</BaseLayout>
